@import "tailwindcss" source(none);
@source "{{ site_path }}";
@plugin '@tailwindcss/typography';
@plugin "@tailwindcss/forms";

@font-face {
  font-family: 'Work Sans';
  src: url('../fonts/work-sans.ttf') format('truetype');
  font-weight: 100 900;
  font-style: normal;
}
@font-face {
  font-family: 'Work Sans';
  src: url('../fonts/work-sans-italic.ttf') format('truetype');
  font-weight: 100 900;
  font-style: italic;
}

@theme {
  --font-sans: "Work Sans", ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";

  --color-*: initial;
  --color-white: #fff;
  --color-black: #000;

  --color-grey-50: #F7F7F7;   /* BSK-2015 */
  --color-grey-100: #EEEEEE;  /* BSK-2015 */
  --color-grey-300: #999999;  /* BSK-2015 */
  --color-grey-500: #757575;  /* BSK 2015 777777, darkened for WCAG AA */
  --color-grey-700: #555555;  /* BSK-2015 */
  --color-grey-900: #333333;  /* BSK-2015 */
  --color-grey-950: #222222;  /* BSK-2015 */

  --color-sky-blue-50: #EFF4F7;   /* BSK-2025 */
  --color-sky-blue-500: #2B8CC4;  /* BSK-2015 */
  --color-blue-300: #547B92;      /* BSK-2015 */
  --color-blue-500: #003B5C;      /* BSK-2025 */

  --color-yellow-500: #FFBF47;  /* BSK-2015 */
  --color-yellow-700: #AB8030;  /* BSK-2015 */
  --color-red-500: #B10E1E;     /* BSK-2015 */
  --color-pink-500: #D4357F;    /* BSK 2015 D53880, darkened for WCAG AA */
  --color-green-500: #379245;   /* BSK-2015 */
  --color-mauve-500: #6F72AF;   /* BSK-2015 */
}

@utility prose {
  --tw-prose-body: var(--color-grey-900);
  --tw-prose-invert-body: var(--color-grey-100);
  --tw-prose-headings: var(--color-grey-900);
  --tw-prose-invert-headings: var(--color-grey-100);
  --tw-prose-lead: var(--color-grey-900);
  --tw-prose-invert-lead: var(--color-grey-100);
  --tw-prose-links: var(--color-blue-500);
  --tw-prose-invert-links: var(--color-white);
  --tw-prose-bold: var(--color-grey-900);
  --tw-prose-invert-bold: var(--color-grey-100);
  --tw-prose-counters: var(--color-grey-500);
  --tw-prose-invert-counters: var(--color-grey-300);
  --tw-prose-bullets: var(--color-grey-900);
  --tw-prose-invert-bullets: var(--color-grey-100);
  --tw-prose-hr: var(--color-grey-300);
  --tw-prose-invert-hr: var(--color-grey-500);
  --tw-prose-quotes: var(--color-grey-900);
  --tw-prose-invert-quotes: var(--color-grey-100);
  --tw-prose-quote-borders: var(--color-grey-300);
  --tw-prose-invert-quote-borders: var(--color-grey-500);
  --tw-prose-captions: var(--color-grey-500);
  --tw-prose-invert-captions: var(--color-grey-300);
  --tw-prose-code: var(--color-grey-950);
  --tw-prose-invert-code: var(--color-grey-50);
  --tw-prose-kbd: var(--color-grey-900);
  --tw-prose-invert-kbd: var(--color-grey-100);
  --tw-prose-kbd-shadows: var(--color-grey-300);
  --tw-prose-invert-kbd-shadows: var(--color-grey-500);
  --tw-prose-pre-code: var(--color-grey-100);
  --tw-prose-invert-pre-code: var(--color-grey-900);
  --tw-prose-pre-bg: var(--color-grey-900);
  --tw-prose-invert-pre-bg: var(--color-grey-100);
  --tw-prose-th-borders: var(--color-grey-300);
  --tw-prose-invert-th-borders: var(--color-grey-500);
  --tw-prose-td-borders: var(--color-grey-300);
  --tw-prose-invert-td-borders: var(--color-grey-500);

  .admonition {
    @apply p-4 pr-0 border-l-5;
  }

  .admonition .admonition-title {
    @apply mt-0;
  }

  .admonition-title {
    @apply text-lg font-semibold;
  }

  .admonition.note {
    @apply border-l-sky-blue-500;
  }

  .admonition.tip {
    @apply border-l-green-500;
  }

  .admonition.important {
    @apply border-l-mauve-500;
  }

  .admonition.warning {
    @apply border-l-yellow-500;
  }

  .admonition.caution {
    @apply border-l-red-500;
  }
}
