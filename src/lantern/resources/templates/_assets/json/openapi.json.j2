  "components": {
    "securitySchemes": {
      "ldapMagic": {
        "type": "http",
        "scheme": "basic",
        "description": "Restricted to MAGIC team members via LDAP."
      }
    },
    "schemas": {
      "htmlContent": {
        "title": "HTML content",
        "type": "string",
        "examples": [
          "<!DOCTYPE html>\n\n<html lang=\"en-GB\">...</html>"
        ]
      },
      "htmlRedirect": {
        "title": "HTML redirect content",
        "type": "string",
        "examples": [
          "<!DOCTYPE html>\n\n<html lang=\"en-GB\"><head><title>BAS Data Catalogue</title><meta http-equiv=\"refresh\" content=\"0;url=/items/dbe5f712-696a-47d8-b4a7-3b173e47e3ab/\"></head><body><a href=\"/items/dbe5f712-696a-47d8-b4a7-3b173e47e3ab/\">Click here if you are not redirected after a few seconds.</a></body></html>"
        ]
      },
      "htmlUnauthorised": {
        "title": "HTML 401 content",
        "type": "string",
        "examples": [
          "<!DOCTYPE html>\n\n<html lang=\"en-GB\"><body>Unauthorised. Unable to verify you are authorized to access the information requested.</body></html>"
        ]
      },
      "htmlNotFound": {
        "title": "HTML 404 content",
        "type": "string",
        "examples": [
          "<!DOCTYPE html>\n\n<html lang=\"en-GB\"><body>Page not found.</body></html>"
        ]
      },
      "publicWebsiteSearchItems": {
        "title": "BAS public website additional search items",
        "description": "Subset of catalogue content (resources), for creating search index items in the [BAS public website](https://www.bas.ac.uk).",
        "type": "array",
        "items": {
          "title": "BAS public website additional search item",
          "type": "object",
          "required": [
            "file_identifier",
            "file_revision",
            "source",
            "content",
            "deleted"
          ],
          "additionalProperties": false,
          "properties": {
            "file_identifier": {
              "title": "File identifier",
              "description": "Persistent and unique identifier for a resource.",
              "type": "string",
              "examples": [
                "7b0cd3e3-069e-4fe2-92d4-f2387bfc40f1"
              ]
            },
            "file_revision": {
              "title": "File revision",
              "description": "Identifier for a resource at a specific revision.",
              "type": "string",
              "examples": [
                "2d3358180f619996b6fcf06126b9b3ca4988c5e6"
              ]
            },
            "source": {
              "title": "Source",
              "description": "Identifier to indicate the origin of a resource.",
              "type": "string",
              "enum": [
                "lantern"
              ],
              "examples": [
                "lantern"
              ]
            },
            "content": {
              "title": "Search item content",
              "description": "Subset of resource information necessary for a search item.",
              "type": "object",
              "required": [
                "id",
                "type",
                "title",
                "description",
                "date",
                "version",
                "href"
              ],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "title": "ID",
                  "description": "Persistent and unique identifier for the item.\n\nNot intended to be shown in search results.",
                  "type": "string",
                  "examples": [
                    "7b0cd3e3-069e-4fe2-92d4-f2387bfc40f1"
                  ]
                },
                "revision": {
                  "title": "Revision",
                  "description": "Optional reference for the version of the item.\n\nNot intended to be shown in search results.",
                  "type": "string",
                  "examples": [
                    "2d3358180f619996b6fcf06126b9b3ca4988c5e6"
                  ]
                },
                "type": {
                  "title": "Item Type",
                  "description": "Derived from resource type.",
                  "type": "string",
                  "enum": [
                    "COLLECTION",
                    "DATASET",
                    "INITIATIVE (PROJECT)",
                    "PRODUCT (MAP)",
                    "PRODUCT (PAPER MAP)"
                  ],
                  "examples": [
                    "PRODUCT (MAP)"
                  ]
                },
                "title": {
                  "title": "Title",
                  "description": "Mapped from the resource title.",
                  "type": "string",
                  "examples": [
                    "Fictitious map of mermaid sightings in Antarctica"
                  ]
                },
                "description": {
                  "title": "Description",
                  "description": "Mapped from the resource summary or description.",
                  "type": "string",
                  "examples": [
                    "..."
                  ]
                },
                "date": {
                  "title": "Date",
                  "description": "Mapped from a suitable resource date, typically the publication date.",
                  "type": "date-time",
                  "examples": [
                    "2014-06-30T14:20:42+00:00"
                  ]
                },
                "version": {
                  "title": "Version",
                  "description": "Mapped from the resource edition if available.",
                  "type": "string",
                  "examples": [
                    "1",
                    "2014.2"
                  ]
                },
                "thumbnail_href": {
                  "title": "Thumbnail URL",
                  "description": "URL to an overview thumbnail for the resource if available.",
                  "type": "string",
                  "examples": [
                    "https://cdn.web.bas.ac.uk/item-thumbnails/7b0cd3e3-069e-4fe2-92d4-f2387bfc40f1/overview.png"
                  ]
                },
                "keywords": {
                  "title": "Search keywords",
                  "description": "Derived from resource topic keywords if available.",
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "examples": [
                    [
                      "mermaids",
                      "sightings",
                      "Antarctica",
                      "map",
                      "fictitious"
                    ]
                  ]
                },
                "href": {
                  "title": "Item URL",
                  "description": "URL to the item in the Catalogue.",
                  "type": "string",
                  "examples": [
                    "https://data.bas.ac.uk/items/7b0cd3e3-069e-4fe2-92d4-f2387bfc40f1"
                  ]
                }
              }
            },
            "deleted": {
              "title": "Deleted",
              "description": "Flag to indicate whether the resource has been deleted and should be removed.",
              "type": "boolean",
              "examples": [
                false
              ]
            }
          }
        }
      },
      "checkData": {
        "title": "Catalogue check",
        "description": "Data and results for a single catalogue check.",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "url",
          "http_method",
          "http_status",
          "state",
          "duration",
          "result_http_status",
          "result_output"
        ],
        "properties": {
          "type": {
            "type": "string",
            "title": "Check type",
            "description": "Human-friendly type/category of check.",
            "examples": [
              "Item Pages",
              "NORA Downloads"
            ],
            "enum": [
              "BAS Public Website Search","Item Aliases","Item Pages","Record Pages (JSON)","Record Pages (XML HTML)","Record Pages (XML)","Site Not Found Handler","Site API","Site Health","Site Index","Site Pages","Site Resources","WAF","DOI Redirects","Published Map","Normal Downloads","NORA Downloads","SharePoint Downloads","BAS SAN Downloads","ArcGIS Layer","ArcGIS Service"
            ]
          },
          "url": {
            "type": "string",
            "format": "uri",
            "title": "URL",
            "description": "URL that was checked."
          },
          "http_method": {
            "type": "string",
            "title": "HTTP method",
            "description": "HTTP method used for the check.",
            "examples": [
              "GET",
              "HEAD",
              "POST"
            ]
          },
          "http_status": {
            "type": "integer",
            "title": "Expected HTTP status",
            "description": "HTTP status code expected when the check is executed.",
            "examples": [
              200,
              206,
              404
            ]
          },
          "content_length": {
            "type": [
              "integer",
              "null"
            ],
            "title": "Content length",
            "description": "Expected content length in bytes when known, otherwise null."
          },
          "redirect_location": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri",
            "title": "Redirect location",
            "description": "Expected target URL where checked content is a redirect, otherwise null."
          },
          "file_identifier": {
            "type": [
              "string",
              "null"
            ],
            "title": "File identifier",
            "description": "File/resource identifier where check is associated with a resource, otherwise null."
          },
          "state": {
            "type": "string",
            "title": "State",
            "description": "Check lifecycle/result.",
            "enum": [
              "pending",
              "passed",
              "failed",
              "skipped"
            ]
          },
          "duration": {
            "type": "number",
            "title": "Duration",
            "description": "Time taken for check in seconds (floating point)."
          },
          "result_http_status": {
            "type": [
              "integer",
              "null"
            ],
            "title": "Observed HTTP status",
            "description": "HTTP status code observed if the check has been executed, otherwise null."
          },
          "result_output": {
            "type": "string",
            "description": "Optional additional information readable if the check has been executed, otherwise null",
            "examples": [
              "OK",
              "Bad status: 404 (expected 200)"
            ]
          }
        }
      },
      "checksData": {
        "title": "Catalogue checks data",
        "description": "Structured data for catalogue checks output (as produced by /-/checks/data.json).",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "base_url",
          "commit",
          "time",
          "duration",
          "pass_fail",
          "stats",
          "site_checks",
          "resource_checks"
        ],
        "properties": {
          "base_url": {
            "type": "string",
            "format": "uri",
            "description": "Base URL used for checks."
          },
          "commit": {
            "type": "object",
            "title": "Commit",
            "description": "Revision of the site when checks were performed.",
            "additionalProperties": false,
            "required": [
              "value",
              "href"
            ],
            "properties": {
              "value": {
                "type": "string",
                "title": "Commit hash",
                "description": "Short commit hash or revision identifier."
              },
              "href": {
                "type": "string",
                "format": "uri",
                "title": "Commit URL",
                "description": "Link to the commit in VCS (restricted)."
              }
            }
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "title": "Datetime",
            "description": "Time at which checks were performed, formatted as ISO 8601 string."
          },
          "duration": {
            "type": "number",
            "title": "Duration",
            "description": "Total time taken for checks in seconds (floating point)."
          },
          "pass_fail": {
            "type": "boolean",
            "title": "Pass/Fail",
            "description": "Overall pass/fail boolean for checks."
          },
          "stats": {
            "title": "Statistics",
            "description": "Counts for check states.",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "skipped",
              "failed",
              "passed"
            ],
            "properties": {
              "skipped": {
                "type": "integer",
                "minimum": 0
              },
              "failed": {
                "type": "integer",
                "minimum": 0
              },
              "passed": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "site_checks": {
            "type": "array",
            "title": "Site-level checks",
            "description": "Checks against site-level resources (not tied to a specific file identifier).",
            "items": {
              "$ref": "#/components/schemas/checkData"
            }
          },
          "resource_checks": {
            "type": "object",
            "title": "Resource-level checks",
            "description": "Map of resource/file identifier -> list of checks for that resource.",
            "additionalProperties": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/checkData"
              }
            }
          }
        }
      },
      "jsonIso19115Record": {
        "$ref": "https://metadata-resources.data.bas.ac.uk/bas-metadata-generator-configuration-schemas/v2/iso-19115-0-v4.json"
      }
    },
    "parameters": {
      "fileIdentifier": {
        "name": "fileIdentifier",
        "in": "path",
        "description": "Persistent and unique identifier for a resource.",
        "required": true,
        "schema": {
          "type": "string",
          "examples": [
            "b8b78c6c-fac2-402c-a772-9f518c7121e5"
          ]
        }
      },
      "aliasIdentifier": {
        "name": "aliasIdentifier",
        "in": "path",
        "description": "Alias currently assigned to a resource.",
        "required": true,
        "schema": {
          "type": "string",
          "examples": [
            "mermaid-sightings-in-antarctica"
          ]
        }
      }
    },
    "responses": {
      "recordNotFound": {
        "description": "Record not found.",
        "content": {
          "text/html": {
            "schema": {
              "$ref": "#/components/schemas/htmlNotFound"
            }
          }
        }
      },
      "aliasFound": {
        "description": "Alias found.",
        "headers": {
          "Location": {
            "description": "Referenced content item URL.",
            "schema": {
              "type": "string",
              "format": "uri",
              "examples": [
                "https://data.bas.ac.uk/items/7b0cd3e3-069e-4fe2-92d4-f2387bfc40f1"
              ]
            }
          }
        },
        "content": {
          "text/html": {
            "schema": {
              "$ref": "#/components/schemas/htmlRedirect"
            }
          }
        }
      },
      "aliasNotFound": {
        "description": "Alias not found.",
        "content": {
          "text/html": {
            "schema": {
              "$ref": "#/components/schemas/htmlNotFound"
            }
          }
        }
      }
    }
  }
}
