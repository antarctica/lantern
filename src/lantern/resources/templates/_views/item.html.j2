{% extends "_layouts/main.html.j2" %}
{% import '_macros/item.html.j2' as page %}

{% block head_scripts_extra %}
  <script async src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>
  <script>
    function onTurnstileError(code) {
      const family = Math.trunc(code / 1000);
      if (family === 300 || family === 600 || code === 110200) {
        return;
      }
      throw new Error(`Turnstile error: ${code}`);
    }
  </script>
{% endblock %}

{% block main %}
  <article class="space-y-8 lg:space-y-12">
    {{ page.header(item.page_header) }}
    {{ page.not_tabs({'summary': item.summary, 'graphics': item.graphics, 'sides': item.sides}) }}
    {{ page.tabs({'tabs': item.tabs, 'default_anchor': item.default_tab_anchor}) }}
  </article>
{% endblock %}
