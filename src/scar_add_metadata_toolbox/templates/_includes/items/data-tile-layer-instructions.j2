<div id="item-tl-info-layer-{{ download.id }}" class="bsk-alert bsk-alert-block bsk-alert-outline bsk-alert-info bsk-collapse bsk-fade app-tl-info" role="alert">
    <button type="button" class="bsk-close" data-toggle="collapse" data-target="#item-tl-info-layer-{{ download.id }}" aria-expanded="false" aria-label="Close" aria-controls="#item-tl-info-layer-{{ download.id }}">&times;</button>
    <header class="bsk-alert-heading">
        <div class="bsk-h4">ArcGIS Feature Layer instructions</div>
    </header>
    <div class="bsk-alert-body">
        <p>This item is available as a layer that can be used in ArcGIS.</p>

        <p class="bsk-alert bsk-alert-info bsk-alert-highlight">The data in this layer will always reflect the most recent edition of this dataset, and will therefore change whenever a new edition is published.</p>

        <dl class="bsk-dl-horizontal bsk-dl-horizontal-lg">
            <dt>ArcGIS Item</dt>
            <dd><a href="{{ download.url }}">{{ download.url }}</a></dd>
            {% if download.service_url %}
            <dt>Service Endpoint</dt>
            <dd class="app-overflow-x"><code>{{ download.service_url }}</code></dd>
            {% endif %}
            <dt>Instructions</dt>
            <dd>
                <div>
                    <a href="https://pro.arcgis.com/en/pro-app/3.3/help/data/services/use-vector-tiled-layers.htm">
                        Instructions for Esri ArcGIS Pro
                        <i class="far fa-external-link"></i>
                    </a>
                </div>
            </dd>
        </dl>
    </div>
</div>
