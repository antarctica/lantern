<section class="app-item-tab app-item-extent">
    <div class="bsk-row">
        {% if item.bounding_geographic_extent_embedded_map_href %}
            <div class="bsk-col-12-md-6">
                <iframe src="{{ item.bounding_geographic_extent_embedded_map_href }}" style="border:none;" width="100%" height="500px"></iframe>
            </div>
        {% endif %}
        <div class="bsk-col-12-md-6">
            {% if item.location_keywords %}
                <header><h4>Location keywords</h4></header>
                <ul class="bsk-list-unstyled app-keywords-list fa-ul">
                    {% for location_keyword_set in item.location_keywords %}
                        {% for location_term in location_keyword_set.terms %}
                            <li><span class="fa-li">
                                <i class="far fa-map-pin"></i></span>
                                {{ location_term.term }}
                                    {% if location_term.href %}
                                        <a href="{{ location_term.href }}"><i class="far fa-info-circle"></i></a>
                                    {% endif %}
                                    {% if location_keyword_set.thesaurus %}
                                        <small>
                                            {{ location_keyword_set.thesaurus.title.value }}
                                            {% if location_keyword_set.thesaurus.title.href %}
                                                <a href="{{ location_keyword_set.thesaurus.title.href }}"><i class="far fa-info-circle"></i></a>
                                            {% endif %}
                                        </small>
                                    {% endif %}
                            </li>
                        {% endfor %}
                    {% endfor %}
                </ul>
            {% endif %}

            {% if item.bounding_geographic_extent %}
            <header><h4>Bounding coordinates</h4></header>
            <dl class="bsk-dl">
                <dt>
                    <i class="far fa-border-style fa-flip-horizontal"></i>
                    Top-right corner:
                </dt>
                <dd>North: {{ item.bounding_geographic_extent.bounding_box.north_latitude }}, East: {{ item.bounding_geographic_extent.bounding_box.east_longitude }} </dd>
                <dt>
                    <i class="far fa-border-style fa-flip-vertical"></i>
                    Bottom-left corner:
                </dt>
                <dd>South: {{ item.bounding_geographic_extent.bounding_box.south_latitude }}, West: {{ item.bounding_geographic_extent.bounding_box.west_longitude }} </dd>
            </dl>
            {% endif %}

            {% if item.bounding_geographic_extent and item.bounding_temporal_extent %}<hr>{% endif %}

            {% if item.bounding_temporal_extent %}
                <header><h4>Temporal range</h4></header>
                <div>
                  <strong>From:</strong> {{ item.bounding_temporal_extent.start }},
                  <strong>To:</strong> {{ item.bounding_temporal_extent.end }}
                </div>
            {% endif %}
        </div>
    </div>
</section>
