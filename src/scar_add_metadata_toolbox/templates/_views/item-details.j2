{% extends 'app/_layouts/app.j2' %}
{% from 'bas_style_kit/macros/bsk_pattern_item_type_header.j2' import pattern_item_type_header %}

{% block main_content %}
    {{ pattern_item_type_header('item', item.title_markdown) }}
    <div class="bsk-row">
        <div class="bsk-col-12-md-9">
            {% include 'app/_includes/items/summary-information.j2' %}
        </div>
        <div class="bsk-col-12-md-3">
            {% include 'app/_includes/items/images.j2' %}
        </div>
    </div>

    <noscript>
        <div class="bsk-alert bsk-alert-info bsk-alert-solid">
            This page requires JavaScript. If this is unavailable you can read a <a class="bsk-alert-link" href="/records/{{ item.identifier }}/iso-html/{{ item.identifier }}.xml">text only version</a> of the record this item is based on.
        </div>
    </noscript>

    <nav id="app-item-nav" class="bsk-nav-wrapper bsk-nav-wrapper-tabs" role="navigation">
        <ul class="bsk-nav bsk-nav-tabs" role="tablist">
            {% if item.templates_tabs.is_visible.data %}
                <li {% if item.templates_tabs.active_tab == 'data' %}{{ 'class="bsk-active"' }}{% endif %} role="presentation">
                    <a href="#item-details-data" role="tab" data-toggle="tab">
                        <i class="far fa-cube"></i>
                        Data
                    </a>
                </li>
            {% endif %}
            {% if item.templates_tabs.is_visible.authors %}
                <li {% if item.templates_tabs.active_tab == 'authors' %}{{ 'class="bsk-active"' }}{% endif %} role="presentation">
                    <a href="#item-details-authors" role="tab" data-toggle="tab">
                        <i class="far fa-user-friends"></i>
                        Authors
                    </a>
                </li>
            {% endif %}
            {% if item.templates_tabs.is_visible.licence %}
                <li {% if item.templates_tabs.active_tab == 'licence' %}{{ 'class="bsk-active"' }}{% endif %} role="presentation">
                    <a href="#item-details-licence" role="tab" data-toggle="tab">
                        <i class="far fa-file-certificate"></i>
                        Licence
                    </a>
                </li>
            {% endif %}
            {% if item.templates_tabs.is_visible.extent %}
                <li {% if item.templates_tabs.active_tab == 'extent' %}{{ 'class="bsk-active"' }}{% endif %} role="presentation">
                    <a href="#item-details-extent" role="tab" data-toggle="tab">
                        <i class="far fa-expand-arrows"></i>
                        Extent
                    </a>
                </li>
            {% endif %}
            {% if item.templates_tabs.is_visible.lineage %}
                <li {% if item.templates_tabs.active_tab == 'lineage' %}{{ 'class="bsk-active"' }}{% endif %} role="presentation">
                    <a href="#item-details-lineage" role="tab" data-toggle="tab">
                        <i class="far fa-scroll-old"></i>
                        Lineage
                    </a>
                </li>
            {% endif %}
            {% if item.templates_tabs.is_visible.related %}
                <li {% if item.templates_tabs.active_tab == 'related' %}{{ 'class="bsk-active"' }}{% endif %} role="presentation">
                    <a href="#item-details-related" role="tab" data-toggle="tab">
                        <i class="far fa-books"></i>
                        Related
                    </a>
                </li>
            {% endif %}
            {% if item.templates_tabs.is_visible.additional %}
                <li {% if item.templates_tabs.active_tab == 'additional' %}{{ 'class="bsk-active"' }}{% endif %} role="presentation">
                    <a href="#item-details-additional-information" role="tab" data-toggle="tab">
                        <i class="far fa-info-square"></i>
                        Additional Information
                    </a>
                </li>
            {% endif %}
            {% if item.templates_tabs.is_visible.contact %}
                <li class="bsk-pull-right" role="presentation">
                    <a href="#item-details-contact" role="tab" data-toggle="tab">
                        <i class="far fa-comment-alt-lines"></i>
                        Contact
                    </a>
                </li>
            {% endif %}
        </ul>
        <div class="bsk-tab-content">
            {% if item.templates_tabs.is_visible.data %}
                <div id="item-details-data" class="bsk-tab-pane bsk-fade {% if item.templates_tabs.active_tab == 'data' %}{{ 'bsk-in bsk-active' }}{% endif %}" role="tabpanel">
                    {% include 'app/_includes/items/data.j2' %}
                </div>
            {% endif %}
            {% if item.templates_tabs.is_visible.authors %}
                <div
                    id="item-details-authors"
                    class="bsk-tab-pane bsk-fade {% if item.templates_tabs.active_tab == 'authors' %}{{ 'bsk-in bsk-active' }}{% endif %}"
                    role="tabpanel"
                >
                    {% include 'app/_includes/items/authors.j2' %}
                </div>
            {% endif %}
            {% if item.templates_tabs.is_visible.licence %}
                <div
                    id="item-details-licence"
                    class="bsk-tab-pane bsk-fade {% if item.templates_tabs.active_tab == 'licence' %}{{ 'bsk-in bsk-active' }}{% endif %}"
                    role="tabpanel"
                >
                    {% include 'app/_includes/items/licence.j2' %}
                </div>
            {% endif %}
            {% if item.templates_tabs.is_visible.extent %}
                <div
                    id="item-details-extent"
                    class="bsk-tab-pane bsk-fade {% if item.templates_tabs.active_tab == 'extent' %}{{ 'bsk-in bsk-active' }}{% endif %}"
                    role="tabpanel"
                >
                    {% include 'app/_includes/items/extent.j2' %}
                </div>
            {% endif %}
            {% if item.templates_tabs.is_visible.lineage %}
                <div id="item-details-lineage" class="bsk-tab-pane bsk-fade {% if item.templates_tabs.active_tab == 'lineage' %}{{ 'bsk-in bsk-active' }}{% endif %}" role="tabpanel">
                    {% include 'app/_includes/items/lineage.j2' %}
                </div>
            {% endif %}
            {% if item.templates_tabs.is_visible.related %}
                <div id="item-details-related" class="bsk-tab-pane bsk-fade {% if item.templates_tabs.active_tab == 'related' %}{{ 'bsk-in bsk-active' }}{% endif %}" role="tabpanel">
                    {% include 'app/_includes/items/related.j2' %}
                </div>
            {% endif %}
            {% if item.templates_tabs.is_visible.additional %}
                <div id="item-details-additional-information" class="bsk-tab-pane bsk-fade {% if item.templates_tabs.active_tab == 'additional' %}{{ 'bsk-in bsk-active' }}{% endif %}" role="tabpanel">
                    {% include 'app/_includes/items/additional-information.j2' %}
                </div>
            {% endif %}
            {% if item.templates_tabs.is_visible.contact %}
                <div id="item-details-contact" class="bsk-tab-pane bsk-fade {% if item.templates_tabs.active_tab == 'contact' %}{{ 'bsk-in bsk-active' }}{% endif %}" role="tabpanel">
                    {% include 'app/_includes/items/contact.j2' %}
                </div>
            {% endif %}
        </div>
    </nav>
{% endblock %}

{% block styles %}
    {{ super() }}
    <link rel="stylesheet" href="/static/css/map.css" />
{% endblock %}

{% block scripts %}
    {{ super() }}
    <script src="/static/js/item.js"></script>
{% endblock %}
