{
  "$id": "https://metadata-resources.data.bas.ac.uk/scar-add-metadata-toolbox-downloads-proxy-schemas/v1/artefact-lookups-v1.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SCAR ADD Metadata Toolbox - Downloads Proxy v1 artefacts lookup schema",
  "description": "Schema for resource artefacts available within the Downloads Proxy within the SCAR ADD Metadata Toolbox (version 1)",
  "definitions": {
    "artefacts": {
      "title": "Artefacts",
      "description": "Set of artefacts that can be downloaded via this service.",
      "type": "object",
      "patternProperties": {
    ".*": {
      "properties": {
        "artefact_id": {
          "$ref": "#/definitions/artefact_id"
        },
        "resource_id": {
          "$ref": "#/definitions/resource_id"
        },
        "media_type": {
          "$ref": "#/definitions/media_type"
        },
        "origin_uri": {
          "$ref": "#/definitions/origin_uri"
        }
      },
      "required": [
        "artefact_id",
        "resource_id",
        "media_type",
        "origin_uri"
      ],
      "additionalProperties": false
    }
  }
    },
    "artefact_id": {
      "title": "Artefact Identifier",
      "description": "Identifier for the artefact within a resource being downloaded. Must be a UUID (v4).",
      "type": "string",
      "pattern": "^[\\da-f]{8}-[\\da-f]{4}-[\\da-f]{4}-[\\da-f]{4}-[\\da-f]{12}$",
      "minLength": 36,
      "maxLength": 36,
      "examples": [
        "758ab069-46d7-47b7-82d4-1905ed155a54"
      ]
    },
    "_id": {
      "title": "ID",
      "description": "Instance identifier",
      "type": "string",
      "format": "uri",
      "examples": ["https://example.com/instance.json"]
    },
    "media_type": {
      "title": "Media Type",
      "description": "Where possible the IANA assigned media-type for the artefact being downloaded. If unassigned, a conventional/local media-type can be used.",
      "type": "string",
      "examples": [
        "application/geopackage+vnd.sqlite3"
      ]
    },
    "origin_uri": {
      "title": "Origin URI",
      "description": "URI to the artefact being downloaded within its origin (actual) data access system.",
      "type": "string",
      "format": "uri",
      "examples": [
        "https://example.com/dataset.gpkg"
      ]
    },
    "resource_id": {
      "title": "Resource Identifier",
      "description": "Identifier for the resource the artefact being downloaded is part of. Must be a UUID (v4).",
      "type": "string",
      "pattern": "^[\\da-f]{8}-[\\da-f]{4}-[\\da-f]{4}-[\\da-f]{4}-[\\da-f]{12}$",
      "minLength": 36,
      "maxLength": 36,
      "examples": [
        "beaa0a4e-e452-4087-b4f5-eb2b8246dedb"
      ]
    },
    "_schema": {
      "title": "Schema",
      "description": "Schema identifier",
      "type": "string",
      "format":  "uri",
      "examples":  ["https://example.com/schema.json"]
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["artefacts"],
  "properties": {
    "$id": {
      "$ref": "#/definitions/_id"
    },
    "$schema": {
      "$ref": "#/definitions/_schema"
    },
    "artefacts": {
      "$ref": "#/definitions/artefacts"
    }
  }
}
